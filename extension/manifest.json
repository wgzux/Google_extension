{
    "manifest_version": 3,
    "name": "Redmine Helper",
    "description": "Enhanced UI and management tools for Redmine",
    "version": "3.0.0",
    "action": {
        "default_icon": "images/icon.png",
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "permissions": [
        "activeTab",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": [
                "lib/jquery.min.js",
                "lib/clipboard.min.js",
                "content/modules/issue-tree.js",
                "content/modules/bug-manager.js",
                "content/redmine.js"
            ],
            "css": [
                "content/redmine.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["images/*"],
            "matches": ["<all_urls>"]
        }
    ]
}
